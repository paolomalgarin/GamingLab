% --- Colori ---
\definecolor{gameOrange}{RGB}{255, 102, 0}
\definecolor{keyTop}{RGB}{250, 250, 250}
\definecolor{keySide}{RGB}{180, 180, 180}
\definecolor{darkGrey}{RGB}{30, 30, 30}
\definecolor{grey}{RGB}{50, 50, 50}

% --- Configurazione Ombre Globale ---
\shadowoffset{1.5pt}

% --- Gestione Spazi e Stile Titoli ---
% Sottotitolo: 8pt sopra, 2pt sotto (per avvicinare i tasti)
\titlespacing*{\subsection}{0pt}{8pt}{2pt}

% Sezione con ombra grigia (shadowoffset ridotto a 1pt come da tua versione)
\titleformat{\section}
  {\normalfont\Large\bfseries\color{gameOrange}}
  {}{0pt}
  {\shadowcolor{grey}\shadowoffset{1pt}\shadowtext}

% --- Automazione Tasti (Keybindings) ---
\newcommand{\keyb}[1]{%
    \begin{tikzpicture}[baseline=(node.base)]
        \node[draw=keySide, fill=keySide, thick, rounded corners=2pt, inner sep=4pt, minimum width=1.8em, minimum height=1.8em] (base) {\phantom{\texttt{\textbf{#1}}}};
        \node[draw=darkGrey, fill=keyTop, thick, rounded corners=2pt, inner sep=4pt, minimum width=1.8em, minimum height=1.8em, yshift=2.5pt] (node) at (base.center) {\texttt{\textbf{#1}}};
    \end{tikzpicture}%
}

\newcommand{\addKeybindings}[2]{%
    \noindent
    \foreach \tasto [count=\i] in {#1} {%
        \ifnum\i>1 \hspace{2pt} \fi
        \keyb{\tasto}%
    }
    \quad \textbf{#2} \vspace{0.15cm} \\ 
}

% --- Automazione Immagini con Descrizione ---
\newcommand{\addGameImage}[2]{%
    \begin{center}
        \begin{tcolorbox}[
            enhanced, 
            colback=black!90, 
            colframe=gameOrange, 
            sharp corners, 
            boxrule=1.5pt, 
            width=0.95\linewidth, 
            halign=center, 
            drop shadow, 
            left=0pt, right=0pt, top=0pt, bottom=0pt,
            boxsep=0pt
        ]
            \includegraphics[width=\linewidth, height=8cm, keepaspectratio]{#1}
        \end{tcolorbox}
        \vspace{-5pt} 
        \small \textit{\textcolor{darkGrey}{#2}}
    \end{center}
}

% --- LOGICA PIXEL RELATIVA (Simmetria perfetta) ---
\newcommand{\drawPixelPattern}[3]{
    \begin{scope}[shift={(#1)}]
        \def\px{14pt}
        \fill[gameOrange] (0,0) rectangle ++(#2*\px/4, #3*-\px/4);
        \fill[gameOrange] (#2*\px/2, 0) rectangle ++(#2*\px/2, #3*-\px/2);
        \fill[gameOrange] (0, #3*-\px/2) rectangle ++(#2*\px/2, #3*-\px/2);
        \fill[gameOrange] (#2*\px/2, #3*-\px/2) rectangle ++(#2*\px/2, #3*-\px/2);
        \fill[gameOrange] (#2*\px + #2*1, 0) rectangle ++(#2*\px, #3*-\px);
        \fill[gameOrange] (0, #3*-\px - #3*1) rectangle ++(#2*\px, #3*-\px);
        \fill[gameOrange] (0, #3*-\px*2 - #3*2) rectangle ++(#2*\px/2, #3*-\px/2);
        \fill[gameOrange] (#2*\px*2 + #2*2, 0) rectangle ++(#2*\px/2, #3*-\px/2);
        \fill[gameOrange] (0, #3*-\px*2.5 - #3*2) rectangle ++(#2*\px/4, #3*-\px/2);
        \fill[gameOrange] (#2*\px*2.5 + #2*2, 0) rectangle ++(#2*\px/2, #3*-\px/4);
        \fill[gameOrange] (#2*\px + #2*1, #3*-\px - #3*1) rectangle ++(#2*\px/4, #3*-\px/4);
    \end{scope}
}

% --- Ambiente Documento (MULTIPAGINA) ---
\newenvironment{ManualDocument}[2]{%
    \begin{tcolorbox}[
        enhanced, 
        empty, 
        breakable, 
        width=\textwidth, 
        left=20pt, right=20pt, top=10pt, bottom=10pt,
        boxsep=0pt,
        overlay unbroken and first={
            \drawPixelPattern{frame.north west}{1}{1}
            \drawPixelPattern{frame.north east}{-1}{1}
        },
        overlay unbroken and last={
            \drawPixelPattern{frame.south west}{1}{-1}
            \drawPixelPattern{frame.south east}{-1}{-1}
        }
    ]
    \begin{center}
        \vspace{0.1cm}
        % Icona sopra il titolo (assicurati che il file esista, es: icon.png o img/icon.png)
        \includegraphics[width=.7cm]{#2} \\ 
        \vspace{0.4cm}
        % Titolo con ombra Nera e offset originale (1.5pt)
        {\Huge \textbf{\shadowcolor{black}\shadowoffset{1.5pt}\shadowtext{\textcolor{gameOrange}{#1}}}} \\
        \vspace{0.5cm}
    \end{center}
}{%
    \vfill
    \begin{center}
        \textcolor{darkGrey}{\texttt{>> SYSTEM READY <<}}
    \end{center}
    \end{tcolorbox}
}